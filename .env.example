# Production Docker Compose environment template.
#
# Quick start:
#   cp .env.example .env
#   # edit the values you care about
#   docker compose up -d --build
#
# Access:
#   http://<your-server-ip>:5173
#
# Notes:
# - `SECRET_ENCRYPTION_KEY` can be left empty. The backend container will
#   auto-generate and persist it inside the `ainovel_app_data` Docker volume.
# - Leave `AUTH_ADMIN_USER_ID` / `AUTH_ADMIN_PASSWORD` empty to skip automatic
#   admin bootstrap. You can then register the first account from the UI.
# - If you set `AUTH_ADMIN_PASSWORD`, use a strong password with length >= 8.

APP_ENV=prod
LOG_LEVEL=INFO

# Web / API ports
FRONTEND_PORT=5173
BACKEND_PORT=8000

# Postgres
POSTGRES_DB=ainovel
POSTGRES_USER=ainovel
POSTGRES_PASSWORD=change-this-postgres-password

# Optional direct DATABASE_URL override. Usually you can leave it empty and let
# docker-compose.yml derive it from the Postgres variables above.
DATABASE_URL=

# Secrets (optional; auto-generated + persisted when empty)
SECRET_ENCRYPTION_KEY=
AUTH_SESSION_SIGNING_KEY=

# Optional admin bootstrap
AUTH_ADMIN_USER_ID=
AUTH_ADMIN_PASSWORD=
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_DISPLAY_NAME=管理员

# Optional browser / CORS override. In the standard deployment path the browser
# talks to the frontend on port 5173 and Nginx proxies `/api` internally, so the
# default is usually enough.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_COOKIE_SAMESITE=lax

# Queue / runtime
RQ_QUEUE_NAME=default
RQ_WORKER_PROCESSES=1
WEB_CONCURRENCY=2
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800

# LinuxDo OIDC (optional)
LINUXDO_OIDC_CLIENT_ID=
LINUXDO_OIDC_CLIENT_SECRET=
LINUXDO_OIDC_REDIRECT_URI=
LINUXDO_OIDC_SCOPES=openid profile email
