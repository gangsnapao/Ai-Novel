# Frontend (.env.example)
#
# This file is a template. Copy it to `.env` if you want local overrides:
#   copy .env.example .env
#
# IMPORTANT: Never commit real secrets to git.

# Enable the frontend dev-fallback auth mode (DEV only).
# - Default: disabled (dev_fallback will NOT be entered)
# - Set to "true" to allow entering dev_fallback when backend permits it
# - Backend must run with `APP_ENV=dev` (prod must keep this disabled)
VITE_DEV_FALLBACK_ENABLED=false
